# Temperature Poller API Configuration
# Copy this file to .env and modify as needed
#
# NOTE: Main configuration (region, API URL, polling settings) 
# is in config.json at the project root.
# This file is for API server settings only.

# =============================================================================
# Server Configuration
# =============================================================================

# Host to bind the server
HOST=0.0.0.0

# Port to bind the server
PORT=8000

# Enable auto-reload on code changes (development only)
RELOAD=false

# Log level: debug, info, warning, error
LOG_LEVEL=info

# =============================================================================
# Override config.json (Optional)
# =============================================================================

# Uncomment to override config.json settings:
# REGION_PREFIX=NS
# API_BASE_URL=http://localhost:8001
# DB_BASE_DIR=databases
